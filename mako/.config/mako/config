max-history=50
sort=-time

layer=overlay
anchor=top-right

font=Lexend Deca Medium 10
width=300
height=110
margin=10
padding=15
border-size=2
border-radius=10
icons=1
max-icon-size=48

background-color=#191724cc
text-color=#e0def4
border-color=#c4a7e7
progress-color=source #26233a

[urgency=low]
default-timeout=2500

[urgency=normal]
default-timeout=5000

[urgency=critical]
default-timeout=10000
